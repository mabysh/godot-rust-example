[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]
linux.debug.x86_64 = "res://../server-lib/target/debug/libserver_lib.so"
linux.release.x86_64 = "res://../server-lib/target/release/libserver_lib.so"
windows.debug.x86_64 = "res://../server-lib/target/debug/server_lib.dll"
windows.release.x86_64 = "res://../server-lib/target/release/server_lib.dll"
macos.debug = "res://../server-lib/target/debug/libserver_lib.dylib"
macos.release = "res://../server-lib/target/release/libserver_lib.dylib"
macos.debug.arm64 = "res://../server-lib/target/debug/libserver_lib.dylib"
macos.release.arm64 = "res://../server-lib/target/release/libserver_lib.dylib"
